             :open-a "open -a \"%s\""
             :hs-resize "/opt/homebrew/bin/hs -c \"ResizeWindow('%s')\""
             :tmux-edit-and-switch "/opt/homebrew/bin/tmux send-keys -t %s \":edit %s\" ENTER && /opt/homebrew/bin/tmux switch -t %s"
